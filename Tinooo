#include <iostream>
#include <queue>
#include <string>

using namespace std;

int main() {
    int n;
    cin >> n;

    queue<string> red;

    for (int i = 0; i < n; i++) {
        string naredba;
        cin >> naredba;

        if (naredba == "DODAJ") {
            string ime;
            cin >> ime;
            red.push(ime);
        }

        else if (naredba == "OBRADI") {
            red.pop();
        }

        else if (naredba == "PRVI") {
            if (red.empty()) {
                cout << "PRAZNO" << endl;
            } else {
                cout << red.front() << endl;
            }
        }

        else if (naredba == "BROJ") {
            cout << red.size() << endl;
        }
    }

    return 0;
}
